---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Contact Us"
  description="Contact Shield Fire Protection — Winnipeg and Manitoba fire protection inspection and service. Call (204) 555-0100. Monday–Friday, 8:00 AM – 5:00 PM."
>

  <!-- ── PAGE HERO ─────────────────────────────────────────────── -->
  <section class="pt-40 pb-24 bg-brand-dark-2">
    <div class="max-w-7xl mx-auto px-6">
      <span class="section-label mb-5 inline-block animate-on-scroll anim-fade" data-hero-i="0">Get In Touch</span>
      <h1 class="text-5xl md:text-7xl font-black text-white leading-tight animate-on-scroll anim-fade" data-hero-i="1">
        Let's talk about<br/>your building.
      </h1>
      <p class="text-white/50 mt-6 text-lg max-w-xl leading-relaxed animate-on-scroll anim-fade" data-hero-i="2">
        We respond quickly, quote honestly, and show up when we say we will. No runaround.
      </p>
    </div>
  </section>

  <!-- ── MAIN CONTENT ──────────────────────────────────────────── -->
  <section class="bg-brand-dark py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">

        <!-- Left: contact info -->
        <div class="space-y-12 animate-on-scroll anim-slide-left">

          <!-- Phone -->
          <div>
            <h2 class="text-white/25 text-xs font-semibold tracking-widest uppercase mb-4">Call Us</h2>
            <a
              href="tel:2045550100"
              class="text-4xl font-black text-white hover:text-brand-orange transition-colors duration-200"
            >
              (204) 555&#8209;0100
            </a>
            <p class="text-white/40 text-sm mt-2">
              We pick up — give us a call and we'll get you sorted.
            </p>
          </div>

          <!-- Hours -->
          <div>
            <h2 class="text-white/25 text-xs font-semibold tracking-widest uppercase mb-4">Hours of Operation</h2>
            <div class="space-y-2">
              <div class="flex justify-between items-center py-3 border-b border-white/8">
                <span class="text-white text-sm font-medium">Monday – Friday</span>
                <span class="text-white/60 text-sm">8:00 AM – 5:00 PM</span>
              </div>
              <div class="flex justify-between items-center py-3 border-b border-white/8">
                <span class="text-white text-sm font-medium">Saturday</span>
                <span class="text-white/30 text-sm">Closed</span>
              </div>
              <div class="flex justify-between items-center py-3">
                <span class="text-white text-sm font-medium">Sunday</span>
                <span class="text-white/30 text-sm">Closed</span>
              </div>
            </div>
          </div>

          <!-- Address -->
          <div>
            <h2 class="text-white/25 text-xs font-semibold tracking-widest uppercase mb-4">Service Area</h2>
            <p class="text-white text-sm font-medium">123 Main Street, Winnipeg, MB R3C 0A1</p>
            <p class="text-white/45 text-sm mt-2 leading-relaxed">
              Based in Winnipeg. We service Winnipeg and surrounding Manitoba communities.
            </p>
          </div>

          <!-- Social -->
          <div>
            <h2 class="text-white/25 text-xs font-semibold tracking-widest uppercase mb-4">Find Us</h2>
            <div class="flex gap-4">
              <a href="#" class="inline-flex items-center gap-2 text-white/50 hover:text-white text-sm font-medium transition-colors duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
              <a href="#" class="inline-flex items-center gap-2 text-white/50 hover:text-white text-sm font-medium transition-colors duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Instagram
              </a>
            </div>
          </div>

        </div>

        <!-- Right: form (decorative) -->
        <div class="bg-brand-dark-2 rounded-sm p-8 border border-white/5 animate-on-scroll anim-slide-right">
          <h2 class="text-white font-bold text-lg mb-2">Send Us a Message</h2>
          <p class="text-white/40 text-sm mb-8">Fill out the form and we'll follow up by phone or email.</p>

          <form class="space-y-5">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-white/35 text-xs font-semibold tracking-widest uppercase mb-2">First Name</label>
                <input type="text" class="input-field" placeholder="John" />
              </div>
              <div>
                <label class="block text-white/35 text-xs font-semibold tracking-widest uppercase mb-2">Last Name</label>
                <input type="text" class="input-field" placeholder="Smith" />
              </div>
            </div>

            <div>
              <label class="block text-white/35 text-xs font-semibold tracking-widest uppercase mb-2">Email</label>
              <input type="email" class="input-field" placeholder="john@yourbuilding.com" />
            </div>

            <div>
              <label class="block text-white/35 text-xs font-semibold tracking-widest uppercase mb-2">Phone (optional)</label>
              <input type="tel" class="input-field" placeholder="(204) 555-0100" />
            </div>

            <div>
              <label class="block text-white/35 text-xs font-semibold tracking-widest uppercase mb-2">Message</label>
              <textarea
                rows="5"
                class="input-field resize-none"
                placeholder="Tell us about your property, what systems you have, and what you need..."
              ></textarea>
            </div>

            <button type="button" class="btn-primary w-full text-center py-4">
              Send Message
            </button>

            <p class="text-white/20 text-xs text-center">
              We'll get back to you within one business day.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- ── MAP PLACEHOLDER ───────────────────────────────────────── -->
  <section class="bg-brand-dark-2">
    <div class="max-w-7xl mx-auto px-6 pb-28">
      <div class="rounded-sm overflow-hidden animate-on-scroll anim-fade">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d19770.55!2d-97.1384!3d49.8954!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sca!4v1700000000000!5m2!1sen!2sca"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

</BaseLayout>
