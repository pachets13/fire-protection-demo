---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home" description="Shield Fire Protection — Winnipeg's trusted fire protection inspection, maintenance, and service company. Red Seal certified, City of Winnipeg licensed. 20+ years serving Manitoba.">

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">

    <!-- Background slideshow -->
    <div class="absolute inset-0" id="hero-slideshow">
      <img src={`${base}/images/slideshow-1.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 opacity-100" data-hero-slide />
      <img src={`${base}/images/slideshow-2.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 opacity-0" data-hero-slide />
      <img src={`${base}/images/slideshow-3.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 opacity-0" data-hero-slide />
      <img src={`${base}/images/slideshow-4.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 opacity-0" data-hero-slide />
      <img src={`${base}/images/slideshow-5.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-1000 opacity-0" data-hero-slide />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/80 via-brand-dark/65 to-brand-dark"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-24">
      <span class="section-label mb-5 inline-block animate-on-scroll anim-fade" data-hero-i="0">Manitoba's Trusted Fire Protection</span>
      <h1 class="text-6xl md:text-8xl font-black tracking-tight text-white leading-none mb-6 animate-on-scroll anim-fade" data-hero-i="1">
        Protecting<br/>
        What Matters<br/>
        <span class="text-brand-orange">Most.</span>
      </h1>
      <p class="text-white/60 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed animate-on-scroll anim-fade" data-hero-i="2">
        Family-run fire protection inspection, maintenance, and service across Winnipeg and surrounding Manitoba — backed by 20+ years of follow-through.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll anim-fade" data-hero-i="3">
        <a href={`${base}/contact`} class="btn-primary px-8 py-4 text-xs">Work With Us</a>
        <a href={`${base}/services`} class="btn-outline px-8 py-4 text-xs">View Services</a>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/20 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ── STATS BAR ─────────────────────────────────────────────── -->
  <section class="bg-brand-orange py-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-stagger>
        <div class="animate-on-scroll">
          <p class="text-4xl font-black text-white">20+</p>
          <p class="text-white/70 text-xs uppercase tracking-widest mt-1 font-semibold">Years in Service</p>
        </div>
        <div class="animate-on-scroll">
          <p class="text-4xl font-black text-white">11</p>
          <p class="text-white/70 text-xs uppercase tracking-widest mt-1 font-semibold">Service Types</p>
        </div>
        <div class="animate-on-scroll">
          <p class="text-2xl font-black text-white leading-tight">Red Seal</p>
          <p class="text-white/70 text-xs uppercase tracking-widest mt-1 font-semibold">Certified Journeymen</p>
        </div>
        <div class="animate-on-scroll">
          <p class="text-2xl font-black text-white leading-tight">Licensed</p>
          <p class="text-white/70 text-xs uppercase tracking-widest mt-1 font-semibold">City of Winnipeg</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── VALUE PROPS ───────────────────────────────────────────── -->
  <section class="bg-brand-dark-2 py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="section-label mb-4 inline-block">Why Shield?</span>
        <h2 class="text-4xl md:text-5xl font-black text-white">Built on trust.<br/>Proven by work.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>

        <!-- Who We Are -->
        <div class="bg-brand-dark rounded-sm p-8 border border-white/5 group hover:border-brand-orange/30 transition-colors duration-300 animate-on-scroll">
          <div class="w-10 h-10 bg-brand-orange/15 rounded-sm flex items-center justify-center mb-6 group-hover:bg-brand-orange/25 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Who We Are</h3>
          <p class="text-white/50 leading-relaxed text-sm">
            A family-run fire protection company serving Winnipeg and surrounding areas for over 20 years. We treat every client's building like it's our own.
          </p>
          <a href={`${base}/about`} class="inline-flex items-center gap-1 mt-6 text-brand-orange text-xs font-semibold tracking-widest uppercase hover:text-brand-orange-light transition-colors">
            About Us
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- What We Offer -->
        <div class="bg-brand-dark rounded-sm p-8 border border-white/5 group hover:border-brand-orange/30 transition-colors duration-300 animate-on-scroll">
          <div class="w-10 h-10 bg-brand-orange/15 rounded-sm flex items-center justify-center mb-6 group-hover:bg-brand-orange/25 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">What We Offer</h3>
          <p class="text-white/50 leading-relaxed text-sm">
            Sprinkler inspections, backflow testing, fire pump service, alarm testing, fire dampers, extinguishers, emergency lighting — full-spectrum fire protection.
          </p>
          <a href={`${base}/services`} class="inline-flex items-center gap-1 mt-6 text-brand-orange text-xs font-semibold tracking-widest uppercase hover:text-brand-orange-light transition-colors">
            Our Services
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Why Choose Us -->
        <div class="bg-brand-dark rounded-sm p-8 border border-white/5 group hover:border-brand-orange/30 transition-colors duration-300 animate-on-scroll">
          <div class="w-10 h-10 bg-brand-orange/15 rounded-sm flex items-center justify-center mb-6 group-hover:bg-brand-orange/25 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Why Choose Us</h3>
          <p class="text-white/50 leading-relaxed text-sm">
            We do what we say we'll do. Fast inspection reports, quick invoicing, proactive compliance guidance — and Red Seal certified journeymen on every job.
          </p>
          <a href={`${base}/contact`} class="inline-flex items-center gap-1 mt-6 text-brand-orange text-xs font-semibold tracking-widest uppercase hover:text-brand-orange-light transition-colors">
            Work With Us
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CERTIFICATIONS ────────────────────────────────────────── -->
  <section class="bg-brand-light py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="text-brand-orange uppercase text-xs font-semibold tracking-widest mb-4 inline-block">Credentials</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark">Certified. Licensed. Trusted.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>

        <div class="bg-white rounded-sm p-8 border border-gray-100 text-center shadow-sm animate-on-scroll">
          <div class="w-14 h-14 bg-brand-orange/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-dark text-base mb-2">Red Seal Certified</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Red Seal Sprinkler Fitters — journeymen certified to NFPA 13 & 25 standards.
          </p>
        </div>

        <div class="bg-white rounded-sm p-8 border border-gray-100 text-center shadow-sm animate-on-scroll">
          <div class="w-14 h-14 bg-brand-orange/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-dark text-base mb-2">City of Winnipeg Licensed</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Licensed inspectors authorized by the City of Winnipeg to conduct official fire protection inspections.
          </p>
        </div>

        <div class="bg-white rounded-sm p-8 border border-gray-100 text-center shadow-sm animate-on-scroll">
          <div class="w-14 h-14 bg-brand-orange/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-brand-dark text-base mb-2">Licensed Backflow Testers</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Registered with the City of Winnipeg Backflow Preventor Office for certified annual testing.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PHOTO CTA ─────────────────────────────────────────────── -->
  <section class="overflow-hidden">
    <div class="flex flex-col-reverse lg:flex-row min-h-[480px]">

      <!-- Left: dark text panel -->
      <div class="bg-brand-dark flex items-center lg:w-[45%] px-10 py-20 lg:px-16 xl:px-20">
        <div class="max-w-lg animate-on-scroll anim-fade">
          <span class="section-label mb-5 inline-block">Ready to Get Compliant?</span>
          <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
            Don't wait for a violation letter.
          </h2>
          <p class="text-white/55 text-lg mb-10 leading-relaxed">
            We help Winnipeg building managers stay ahead of inspection requirements — before the city comes knocking.
          </p>
          <a href={`${base}/contact`} class="btn-primary px-10 py-4 text-xs">Get In Touch</a>
        </div>
      </div>

      <!-- Right: photo -->
      <div class="relative lg:w-[55%] min-h-72 lg:min-h-0">
        <img
          src={`${base}/images/slideshow-2.jpg`}
          alt="Shield Fire Protection fleet and team"
          class="absolute inset-0 w-full h-full object-cover object-center"
        />
      </div>

    </div>
  </section>

  <!-- ── CONTACT FORM ──────────────────────────────────────────── -->
  <section class="bg-brand-dark-2 py-28" id="contact">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">

        <!-- Left: info -->
        <div class="animate-on-scroll anim-slide-left">
          <span class="section-label mb-4 inline-block">Get In Touch</span>
          <h2 class="text-4xl font-black text-white mb-6">Let's talk about your building.</h2>
          <p class="text-white/50 leading-relaxed mb-10 text-sm">
            Whether you need an annual inspection, have a backflow concern, or want to understand your compliance requirements — we're straightforward to work with and quick to respond.
          </p>
          <ul class="space-y-4">
            <li class="flex items-center gap-4">
              <span class="w-8 h-8 rounded-sm bg-brand-orange/15 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </span>
              <a href="tel:2045550100" class="text-white/60 hover:text-white text-sm transition-colors">(204) 555-0100</a>
            </li>
            <li class="flex items-center gap-4">
              <span class="w-8 h-8 rounded-sm bg-brand-orange/15 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </span>
              <span class="text-white/60 text-sm">Monday–Friday, 8:00 AM – 5:00 PM</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="w-8 h-8 rounded-sm bg-brand-orange/15 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </span>
              <span class="text-white/60 text-sm">123 Main Street, Winnipeg, MB R3C 0A1</span>
            </li>
          </ul>
        </div>

        <!-- Right: form -->
        <div class="bg-brand-dark rounded-sm p-8 border border-white/5 animate-on-scroll anim-slide-right">
          <form onsubmit="event.preventDefault()">
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-white/40 text-xs font-semibold tracking-widest uppercase mb-2">First Name</label>
                <input type="text" class="input-field" placeholder="John" />
              </div>
              <div>
                <label class="block text-white/40 text-xs font-semibold tracking-widest uppercase mb-2">Last Name</label>
                <input type="text" class="input-field" placeholder="Smith" />
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-white/40 text-xs font-semibold tracking-widest uppercase mb-2">Email</label>
              <input type="email" class="input-field" placeholder="john@yourbuilding.com" />
            </div>
            <div class="mb-6">
              <label class="block text-white/40 text-xs font-semibold tracking-widest uppercase mb-2">Message</label>
              <textarea rows="4" class="input-field resize-none" placeholder="Tell us about your property and what you need..."></textarea>
            </div>
            <button type="button" class="btn-primary w-full text-center py-4">Send Message</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const slideshowEl = document.getElementById('hero-slideshow');
  if (slideshowEl) {
    const slides = Array.from(slideshowEl.querySelectorAll('[data-hero-slide]'));
    if (slides.length > 1) {
      let current = 0;
      setInterval(() => {
        slides[current].classList.remove('opacity-100');
        slides[current].classList.add('opacity-0');
        current = (current + 1) % slides.length;
        slides[current].classList.remove('opacity-0');
        slides[current].classList.add('opacity-100');
      }, 4000);
    }
  }
</script>
