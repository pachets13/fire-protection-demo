---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Shield Fire Protection — Professional fire protection inspection, maintenance, and service in Winnipeg and surrounding Manitoba. 20+ years. Red Seal certified.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/images/favicon.png`} />
    <title>{title} | Shield Fire Protection</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  // ── Hero elements — animate on page load, staggered top-to-bottom
  document.querySelectorAll('[data-hero-i]').forEach(el => {
    const i = parseInt(el.dataset.heroI ?? '0');
    setTimeout(() => el.classList.add('is-visible'), 100 + i * 130);
  });

  // ── Scroll elements — Intersection Observer (animate once)
  const scrollEls = document.querySelectorAll('.animate-on-scroll:not([data-hero-i])');

  if (scrollEls.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        // Sort visible entries top-to-bottom for predictable stagger order
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);

        // Track per-stagger-group counters within this callback batch
        const groupCounters = new Map();

        visible.forEach(entry => {
          const el = entry.target;
          const staggerParent = el.closest('[data-stagger]');

          if (staggerParent) {
            const count = groupCounters.get(staggerParent) ?? 0;
            el.style.transitionDelay = `${count * 100}ms`;
            groupCounters.set(staggerParent, count + 1);
          }

          el.classList.add('is-visible');
          observer.unobserve(el);
        });
      },
      {
        threshold: 0.12,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    scrollEls.forEach(el => observer.observe(el));
  }
</script>
