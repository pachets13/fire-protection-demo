---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Shield Fire Protection — Professional fire protection inspection, maintenance, and service in Winnipeg and surrounding Manitoba. 20+ years. Red Seal certified.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/images/favicon.png`} />
    <title>{title} | Shield Fire Protection</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- ── Floating Call Now button ─────────────────────────── -->
    <a
      id="call-fab"
      href="tel:2045582533"
      aria-label="Call us now"
      class="call-fab"
    >
      <!-- Phone icon -->
      <svg xmlns="http://www.w3.org/2000/svg" class="call-fab__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <!-- Text hidden on mobile via CSS -->
      <span class="call-fab__text">Call Now</span>
    </a>
  </body>
</html>

<style>
  /* ── Floating Call Now button ─────────────────────────────── */
  .call-fab {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 45;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: #E8721C;
    color: #ffffff;
    padding: 1rem 1.625rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(232, 114, 28, 0.45);
    /* Fade-in after 1.5s */
    opacity: 0;
    animation: fabFadeIn 0.4s ease forwards 1.5s;
    transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, opacity 0.3s ease;
  }
  .call-fab:hover {
    background-color: #C55E0F;
    box-shadow: 0 8px 20px rgba(232, 114, 28, 0.5);
    transform: translateY(-2px);
  }
  .call-fab__icon {
    width: 1.375rem;
    height: 1.375rem;
    flex-shrink: 0;
  }
  @keyframes fabFadeIn {
    to { opacity: 1; }
  }
</style>

<script>
  // ── Hero elements — animate on page load, staggered top-to-bottom
  document.querySelectorAll('[data-hero-i]').forEach(el => {
    const i = parseInt(el.dataset.heroI ?? '0');
    setTimeout(() => el.classList.add('is-visible'), 100 + i * 130);
  });

  // ── Scroll elements — Intersection Observer (animate once)
  const scrollEls = document.querySelectorAll('.animate-on-scroll:not([data-hero-i])');

  if (scrollEls.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        // Sort visible entries top-to-bottom for predictable stagger order
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort((a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top);

        // Track per-stagger-group counters within this callback batch
        const groupCounters = new Map();

        visible.forEach(entry => {
          const el = entry.target;
          const staggerParent = el.closest('[data-stagger]');

          if (staggerParent) {
            const count = groupCounters.get(staggerParent) ?? 0;
            el.style.transitionDelay = `${count * 100}ms`;
            groupCounters.set(staggerParent, count + 1);
          }

          el.classList.add('is-visible');
          observer.unobserve(el);
        });
      },
      {
        threshold: 0.12,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    scrollEls.forEach(el => observer.observe(el));
  }
</script>

<script>
  // ── Hide FAB when footer is in view ───────────────────────
  const fab    = document.getElementById('call-fab');
  const footer = document.querySelector('footer');

  if (fab && footer) {
    const footerObserver = new IntersectionObserver(
      ([entry]) => {
        fab.style.opacity = entry.isIntersecting ? '0' : '1';
        fab.style.pointerEvents = entry.isIntersecting ? 'none' : 'auto';
      },
      { threshold: 0.1 }
    );
    footerObserver.observe(footer);
  }
</script>
